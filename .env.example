# Healthcare Navigation AI Agent - Environment Variables

# Groq API Configuration (free tier, function-calling supported)
GROQ_API_KEY=your-groq-key-here

# Optional: Model selection (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Database URL (default: sqlite:///./healthcare.db)
# DATABASE_URL=postgresql://user:password@localhost/healthcare_db

# Optional: Server configuration
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# DEBUG=false